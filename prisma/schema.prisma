generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model About {
  id        Int      @id @default(autoincrement())
  title     String?
  content   String
  updatedAt DateTime @updatedAt
}

model QuickStats {
  id        Int      @id @default(autoincrement())
  label     String
  value     String
  updatedAt DateTime @updatedAt
}

model Service {
  id          Int    @id @default(autoincrement())
  title       String
  description String
}

model Project {
  id       Int    @id @default(autoincrement())
  name     String
  category String
  image    String
}

model Testimonial {
  id     Int    @id @default(autoincrement())
  quote  String
  author String
  role   String
}

model ContactMessage {
  id          String   @id @default(cuid())
  name        String
  email       String
  projectType String
  message     String
  date        DateTime @default(now())
  read        Boolean  @default(false)
}

model FooterLink {
  id    String  @id @default(cuid())
  label String
  href  String
  type  String
  icon  String?
}
