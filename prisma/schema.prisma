generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model About {
  id        Int      @id @default(autoincrement())
  title     String?
  content   String
  updatedAt DateTime @updatedAt
}

model QuickStats {
  id        Int      @id @default(autoincrement())
  level     String
  value     String
  updatedAt DateTime @updatedAt
}
